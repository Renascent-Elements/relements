{
  "name": "@relements/core",
  "version": "0.7.0",
  "description": "HTML-first design system core: tokens, styles, and progressive enhancement.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Renascent-Elements/relements.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Renascent-Elements/relements#readme",
  "bugs": "https://github.com/Renascent-Elements/relements/issues",
  "keywords": [
    "design-system",
    "css",
    "html-first",
    "accessible",
    "progressive-enhancement",
    "framework-agnostic",
    "tokens",
    "components",
    "web-components",
    "aria"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "dist/**/*.css",
    "dist/elements/*.js",
    "src/elements/*.js"
  ],
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./index.css": "./dist/index.css",
    "./tokens.css": "./dist/tokens.css",
    "./reset.css": "./dist/reset.css",
    "./base.css": "./dist/base.css",
    "./components/button.css": "./dist/components/button.css",
    "./components/link.css": "./dist/components/link.css",
    "./components/form.css": "./dist/components/form.css",
    "./components/disclosure.css": "./dist/components/disclosure.css",
    "./components/dialog.css": "./dist/components/dialog.css",
    "./components/progress.css": "./dist/components/progress.css",
    "./components/tabs.css": "./dist/components/tabs.css",
    "./components/menu.css": "./dist/components/menu.css",
    "./components/popover.css": "./dist/components/popover.css",
    "./components/toast.css": "./dist/components/toast.css",
    "./components/accordion.css": "./dist/components/accordion.css",
    "./components/alert.css": "./dist/components/alert.css",
    "./components/avatar.css": "./dist/components/avatar.css",
    "./components/badge.css": "./dist/components/badge.css",
    "./components/breadcrumb.css": "./dist/components/breadcrumb.css",
    "./components/card.css": "./dist/components/card.css",
    "./components/switch.css": "./dist/components/switch.css",
    "./components/tag.css": "./dist/components/tag.css",
    "./components/table.css": "./dist/components/table.css",
    "./components/skeleton.css": "./dist/components/skeleton.css",
    "./components/spinner.css": "./dist/components/spinner.css",
    "./components/pagination.css": "./dist/components/pagination.css",
    "./components/separator.css": "./dist/components/separator.css",
    "./components/kbd.css": "./dist/components/kbd.css",
    "./components/code.css": "./dist/components/code.css",
    "./components/slider.css": "./dist/components/slider.css",
    "./components/tooltip.css": "./dist/components/tooltip.css",
    "./components/combobox.css": "./dist/components/combobox.css",
    "./themes/renascent.css": "./dist/themes/renascent.css",
    "./behaviors/dismissible": {
      "import": "./dist/behaviors/dismissible.js",
      "types": "./dist/behaviors/dismissible.d.ts"
    },
    "./behaviors/dialog": {
      "import": "./dist/behaviors/dialog.js",
      "types": "./dist/behaviors/dialog.d.ts"
    },
    "./behaviors/tabs": {
      "import": "./dist/behaviors/tabs.js",
      "types": "./dist/behaviors/tabs.d.ts"
    },
    "./behaviors/menu-button": {
      "import": "./dist/behaviors/menu-button.js",
      "types": "./dist/behaviors/menu-button.d.ts"
    },
    "./behaviors/popover": {
      "import": "./dist/behaviors/popover.js",
      "types": "./dist/behaviors/popover.d.ts"
    },
    "./behaviors/toast": {
      "import": "./dist/behaviors/toast.js",
      "types": "./dist/behaviors/toast.d.ts"
    },
    "./elements/re-tabs": {
      "import": "./dist/elements/re-tabs.js",
      "types": "./dist/elements/re-tabs.d.ts"
