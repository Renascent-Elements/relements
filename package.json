{
  "name": "relements-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Relements design system monorepo",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "test:a11y": "playwright test tests/a11y",
    "test:visual": "playwright test tests/visual",
    "test:update-snapshots": "playwright test tests/visual --update-snapshots all",
    "build": "pnpm -F @relements/core build",
    "build:examples": "pnpm -F @relements/core build && pnpm --filter \"./docs/examples/frameworks/*\" run build",
    "lint": "prettier --check . && eslint . && pnpm run lint:css",
    "lint:css": "stylelint \"packages/core/src/**/*.css\"",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "eslint-plugin-astro": "^1.7.0",
    "http-server": "^14.1.1",
    "lightningcss": "^1.32.0",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^16.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.4"
  }
}
